# .streamlit/secrets.toml.example
# =====================================================================
# 這是 Streamlit Cloud Secrets 的設定範本
# 請複製此內容，貼入 Streamlit Cloud 的 Secrets 欄位
# （Settings → Secrets）
# =====================================================================

# ── Gemini AI API Key ──────────────────────────────────────────────
GEMINI_API_KEY = "AIza你的Gemini金鑰"

# ── FinMind 台股數據 Token ─────────────────────────────────────────
FINMIND_TOKEN = "你的FinMind_Token"

# ── GitHub Gist 雲端資料庫（持久化用）────────────────────────────
# 1. 到 github.com/settings/tokens 建立 Personal Access Token
#    勾選權限：gist（讀寫 Gist）
# 2. 到 gist.github.com 建立一個新的 Secret Gist（私密）
#    隨便放一個 placeholder.json，取得 Gist URL 中的 ID
GITHUB_TOKEN = "ghp_你的GitHub_Token"
GIST_ID      = "你的Gist_ID（URL中的32位hash）"
