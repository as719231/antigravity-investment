# 請複製本檔案並改名為 .env，然後填入您的金鑰資訊
# 注意：.env 檔案不要分享給別人，也不要上傳到 GitHub

# Google Gemini API Key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# LINE Messaging API Bot 金鑰
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET_HERE
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN_HERE

# 永豐金證券 Shioaji API 資訊
SHIOAJI_API_KEY=YOUR_SHIOAJI_API_KEY_HERE
SHIOAJI_SECRET_KEY=YOUR_SHIOAJI_SECRET_KEY_HERE
SHIOAJI_PERSON_ID=YOUR_ID_CARD_NUMBER_HERE
SHIOAJI_PASSWORD=YOUR_SHIOAJI_LOGIN_PASSWORD_HERE

# 永豐金憑證檔案設定 (下單需要，可填絕對路徑如 C:/憑證/Sinopac.pfx)
SHIOAJI_CA_PATH=C:/path/to/your/certificate.pfx
SHIOAJI_CA_PASSWORD=YOUR_CERTIFICATE_PASSWORD_HERE
